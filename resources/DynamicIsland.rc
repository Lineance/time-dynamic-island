#include <windows.h>

#define IDD_SETTINGS_DIALOG 101
#define IDC_RADIO_24HOUR 201
#define IDC_RADIO_12HOUR 202
#define IDC_CHECK_DATE 203
#define IDC_CHECK_SECONDS 204
#define IDC_CHECK_YEAR 205
#define IDC_RADIO_DARK 206
#define IDC_RADIO_LIGHT 207
#define IDC_RADIO_SYSTEM 208
#define IDC_GROUP_TIME 209
#define IDC_GROUP_DISPLAY 210
#define IDC_GROUP_THEME 211
#define IDC_BTN_APPLY 212
#define IDC_GROUP_SIZE 213
#define IDC_RADIO_SMALL 214
#define IDC_RADIO_MEDIUM 215
#define IDC_RADIO_LARGE 216
#define IDC_GROUP_POSITION 217
#define IDC_RADIO_LEFT 218
#define IDC_RADIO_CENTER 219
#define IDC_RADIO_RIGHT 220
#define IDC_GROUP_HIDE 221
#define IDC_CHECK_AUTOHIDE 222
#define IDC_EDIT_HIDEDELAY_MIN 223
#define IDC_EDIT_HIDEDELAY_SEC 224
#define IDC_SPIN_HIDEDELAY 225
#define IDC_GROUP_FONT 226
#define IDC_EDIT_FONTSIZE 227
#define IDC_SPIN_FONTSIZE 228
#define IDC_CHECK_BOLD 229

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 450, 400
STYLE DS_CENTER | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Dynamic Island Settings"
FONT 9, "MS Shell Dlg 2"
BEGIN
    DEFPUSHBUTTON   "OK", IDOK, 260, 375, 60, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 330, 375, 60, 14
    PUSHBUTTON      "Apply", IDC_BTN_APPLY, 190, 375, 60, 14
    
    GROUPBOX        "Time Format", IDC_GROUP_TIME, 15, 10, 420, 45
    AUTORADIOBUTTON "24-hour (14:30:45)", IDC_RADIO_24HOUR, 30, 26, 140, 10, WS_GROUP
    AUTORADIOBUTTON "12-hour (02:30:45 PM)", IDC_RADIO_12HOUR, 200, 26, 140, 10
    
    GROUPBOX        "Display Options", IDC_GROUP_DISPLAY, 15, 60, 420, 45
    CHECKBOX        "Show Date (01/02)", IDC_CHECK_DATE, 30, 76, 120, 10, BS_AUTOCHECKBOX | WS_TABSTOP
    CHECKBOX        "Show Seconds (:45)", IDC_CHECK_SECONDS, 180, 76, 120, 10, BS_AUTOCHECKBOX | WS_TABSTOP
    CHECKBOX        "Show Year", IDC_CHECK_YEAR, 330, 76, 80, 10, BS_AUTOCHECKBOX | WS_TABSTOP
    
    GROUPBOX        "Theme", IDC_GROUP_THEME, 15, 110, 420, 45
    AUTORADIOBUTTON "Dark", IDC_RADIO_DARK, 30, 126, 80, 10, WS_GROUP
    AUTORADIOBUTTON "Light", IDC_RADIO_LIGHT, 130, 126, 80, 10
    AUTORADIOBUTTON "Follow System", IDC_RADIO_SYSTEM, 230, 126, 120, 10
    
    GROUPBOX        "Window Size", IDC_GROUP_SIZE, 15, 160, 420, 45
    AUTORADIOBUTTON "Small", IDC_RADIO_SMALL, 30, 176, 80, 10, WS_GROUP
    AUTORADIOBUTTON "Medium", IDC_RADIO_MEDIUM, 130, 176, 80, 10
    AUTORADIOBUTTON "Large", IDC_RADIO_LARGE, 230, 176, 80, 10
    
    GROUPBOX        "Position", IDC_GROUP_POSITION, 15, 210, 420, 45
    AUTORADIOBUTTON "Left", IDC_RADIO_LEFT, 30, 226, 80, 10, WS_GROUP
    AUTORADIOBUTTON "Center", IDC_RADIO_CENTER, 130, 226, 80, 10
    AUTORADIOBUTTON "Right", IDC_RADIO_RIGHT, 230, 226, 80, 10
    
    GROUPBOX        "Auto-hide", IDC_GROUP_HIDE, 15, 260, 420, 45
    CHECKBOX        "Enable auto-hide", IDC_CHECK_AUTOHIDE, 30, 276, 120, 10, BS_AUTOCHECKBOX | WS_TABSTOP
    LTEXT           "Hide after:", -1, 170, 276, 60, 10
    EDITTEXT        IDC_EDIT_HIDEDELAY_MIN, 230, 274, 30, 14, ES_NUMBER | WS_TABSTOP
    LTEXT           "min", -1, 265, 276, 25, 10
    EDITTEXT        IDC_EDIT_HIDEDELAY_SEC, 290, 274, 30, 14, ES_NUMBER | WS_TABSTOP
    LTEXT           "sec", -1, 325, 276, 25, 10
    
    GROUPBOX        "Font", IDC_GROUP_FONT, 15, 310, 420, 45
    LTEXT           "Size:", -1, 30, 326, 30, 10
    EDITTEXT        IDC_EDIT_FONTSIZE, 60, 324, 40, 14, ES_NUMBER | WS_TABSTOP
    CHECKBOX        "Bold", IDC_CHECK_BOLD, 130, 326, 60, 10, BS_AUTOCHECKBOX | WS_TABSTOP
    
    LTEXT           "Settings are automatically saved to registry", -1, 15, 360, 420, 10
END
